[base]
env_name = dozerl

[vec]
; total_agents = 2048
total_agents = 1024
backend = Serial

[policy]
; hidden_size = 128
hidden_size = 256
num_layers = 2

[env]


[train]
; total_timesteps = 800_000_000
total_timesteps = 50_000_000
